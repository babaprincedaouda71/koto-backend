### 1. Register Prince (admin)
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{
  "nom": "Coulibaly",
  "prenom": "Prince",
  "telephone": "+22600000000",
  "email": "prince@koto.app",
  "motDePasse": "password123"
}

###

### 2. Login Prince
POST http://localhost:8080/api/auth/login
Content-Type: application/json

{
  "email": "prince@koto.app",
  "motDePasse": "password123"
}

###

### 3. Créer un groupe
POST http://localhost:8080/api/groupes
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzUxMiJ9.eyJzdWIiOiJwcmluY2VAa290by5hcHAiLCJpYXQiOjE3Nzc5MTE0MjgsImV4cCI6MTc3Nzk5NzgyOH0.BCic7brGNHI21JZujcqveMVzh1g2aZAyW3I-xHXIpry7p1I_UZsLV3YKe6RACXrjvOpiDKOngFduv_ly8S39JQ

{
  "nom": "Tontine Famille Coulibaly",
  "montantCotisation": 10000,
  "devise": "XOF",
  "nombreMembres": 6,
  "dateDebut": "2026-06-01"
